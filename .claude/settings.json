{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git status *)",
      "Bash(git worktree list)",

      "Bash(grep -r *)",
      "Bash(grep -rn *)",
      "Bash(grep -rl *)",
      "Bash(grep -c *)",
      "Bash(grep -l *)",
      "Bash(grep -h *)",

      "Bash(npm run check)",
      "Bash(npm run build)",
      "Bash(npm run test:unit*)",

      "Bash(node scripts/verify-chapter*)"
    ]
  }
}
