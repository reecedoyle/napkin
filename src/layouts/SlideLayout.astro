---
import '../styles/global.css';
import {
  getSlideNeighbors,
  getSlideUrlParts,
  getSectionTitle,
  partTitles,
  chapterTitles,
} from '../lib/slide-nav';
import GlossarySidebar from '../components/GlossarySidebar.astro';
import TocSidebar from '../components/TocSidebar.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
const { prev, next, index, total } = getSlideNeighbors(Astro.url.pathname);
const showNav = prev !== undefined || next !== undefined;
const isSlide = total > 0 && index !== undefined;

// Header breadcrumbs are auto-derived from the slide URL so each MDX
// doesn't repeat them. Strip the "Chapter N — " and "§N — " prefixes
// from the title-map values for terser display in the header — the
// numbers are implicit from the chosen path.
const urlParts = getSlideUrlParts(Astro.url.pathname);
const partLabel = urlParts.part ? partTitles[urlParts.part] : undefined;
const chapterKey = urlParts.part && urlParts.chapter ? `${urlParts.part}/${urlParts.chapter}` : '';
const chapterLabel = chapterTitles[chapterKey]?.replace(/^Chapter \d+ — /, '');
const sectionLabel = urlParts.part && urlParts.chapter && urlParts.section
  ? getSectionTitle(urlParts.part, urlParts.chapter, urlParts.section).replace(/^§\d+ — /, '')
  : undefined;
const headerCrumbs = [partLabel, chapterLabel, sectionLabel].filter(
  (s): s is string => Boolean(s),
);

// Render the slot to HTML so we can both inject it as the page body AND
// scan for `data-term-key` attributes emitted by <Term>. The sidebar then
// shows only the glossary entries actually used on this slide.
const slotHtml = Astro.slots.has('default')
  ? await Astro.slots.render('default')
  : '';
const termKeys = isSlide
  ? [...new Set(
      [...slotHtml.matchAll(/data-term-key="([^"]+)"/g)].map((m) => m[1]),
    )]
  : [];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · Napkin</title>

    <link rel="manifest" href={`${import.meta.env.BASE_URL}manifest.webmanifest`} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="apple-touch-icon" href={`${import.meta.env.BASE_URL}apple-touch-icon.png`} />
    <meta name="theme-color" content="#1c1917" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Napkin" />
    <script is:inline src={`${import.meta.env.BASE_URL}registerSW.js`}></script>
  </head>
  <body>
    <header class="border-b border-stone-200 dark:border-stone-800 sticky top-0 z-30 bg-stone-50/95 dark:bg-stone-950/95 backdrop-blur">
      <div class="mx-auto max-w-[760px] px-4 py-3 text-sm text-stone-600 dark:text-stone-400 flex items-center gap-2">
        {isSlide && (
          <button
            type="button"
            class="napkin-toc-toggle inline-flex items-center justify-center rounded-md border border-stone-300 dark:border-stone-700 w-9 h-9 hover:bg-stone-100 dark:hover:bg-stone-900"
            data-toggle="toc"
            aria-label="Show table of contents"
            aria-controls="napkin-drawer-toc"
            aria-expanded="false"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <line x1="4" y1="6" x2="20" y2="6" />
              <line x1="4" y1="12" x2="20" y2="12" />
              <line x1="4" y1="18" x2="20" y2="18" />
            </svg>
          </button>
        )}

        <a href={import.meta.env.BASE_URL} class="inline-flex items-center gap-1.5 hover:underline shrink-0" aria-label="Home — list of chapters">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M3 11l9-8 9 8" />
            <path d="M5 10v10h4v-6h6v6h4V10" />
          </svg>
          <span>Napkin</span>
        </a>

        {headerCrumbs.length > 0 && (
          <span class="text-stone-500 truncate flex-1 min-w-0">
            <span class="hidden md:inline">· {headerCrumbs.join(' · ')}</span>
            <span class="md:hidden">· {headerCrumbs[headerCrumbs.length - 1]}</span>
          </span>
        )}

        {isSlide && (
          <button
            type="button"
            class="napkin-glossary-toggle inline-flex items-center justify-center rounded-md border border-stone-300 dark:border-stone-700 w-9 h-9 hover:bg-stone-100 dark:hover:bg-stone-900 ml-auto"
            data-toggle="glossary"
            aria-label="Show glossary for this slide"
            aria-controls="napkin-drawer-glossary"
            aria-expanded="false"
          >
            <span class="text-amber-700 dark:text-amber-400 text-base leading-none font-serif">†</span>
          </button>
        )}
      </div>
    </header>

    <main class="mx-auto max-w-[760px] px-6 py-12">
      <h1 class="text-3xl font-semibold mb-8 font-serif">{title}</h1>
      <article class="prose prose-stone dark:prose-invert prose-headings:font-serif max-w-none" set:html={slotHtml} />

      {showNav && (
        <nav
          class="not-prose mt-16 pt-6 border-t border-stone-200 dark:border-stone-800 flex items-stretch gap-4 text-sm"
          aria-label="Slide navigation"
        >
          <div class="flex-1">
            {prev && (
              <a
                href={prev.url}
                rel="prev"
                class="block rounded-md border border-stone-200 dark:border-stone-800 px-4 py-3 hover:bg-stone-100 dark:hover:bg-stone-900 transition"
              >
                <div class="text-xs text-stone-500 mb-1">← Previous</div>
                <div class="text-stone-800 dark:text-stone-200">{prev.title}</div>
              </a>
            )}
          </div>

          {index !== undefined && (
            <div class="flex items-center text-stone-500 text-xs px-2 self-center">
              {index + 1} / {total}
            </div>
          )}

          <div class="flex-1 text-right">
            {next && (
              <a
                href={next.url}
                rel="next"
                class="block rounded-md border border-stone-200 dark:border-stone-800 px-4 py-3 hover:bg-stone-100 dark:hover:bg-stone-900 transition"
              >
                <div class="text-xs text-stone-500 mb-1">Next →</div>
                <div class="text-stone-800 dark:text-stone-200">{next.title}</div>
              </a>
            )}
          </div>
        </nav>
      )}
    </main>

    {isSlide && <TocSidebar />}
    {isSlide && <GlossarySidebar keys={termKeys} />}
    {isSlide && (
      <div class="napkin-drawer-backdrop" data-backdrop data-open="false" aria-hidden="true"></div>
    )}

    {isSlide && (
      <script
        is:inline
        define:vars={{ prevUrl: prev?.url ?? null, nextUrl: next?.url ?? null }}
      >
        document.addEventListener('keydown', (e) => {
          // Ignore if a modifier key is held (e.g. Cmd+Left for browser back).
          if (e.metaKey || e.ctrlKey || e.altKey || e.shiftKey) return;
          // Ignore when typing in form fields or contenteditable regions —
          // arrow keys move the cursor there.
          const t = e.target;
          if (t instanceof HTMLElement) {
            if (t.matches('input, textarea, select, [contenteditable=""], [contenteditable="true"]')) return;
          }
          if (e.key === 'ArrowLeft' && prevUrl) {
            e.preventDefault();
            window.location.href = prevUrl;
          } else if (e.key === 'ArrowRight' && nextUrl) {
            e.preventDefault();
            window.location.href = nextUrl;
          }
        });
      </script>
    )}

    {isSlide && (
      <script is:inline>
        // Drawer management for the TOC and Glossary sidebars on narrow
        // viewports. Triggered by the header toggle buttons, the backdrop,
        // ESC, or any in-drawer link click. On wide viewports the sidebars
        // are always visible and the toggle buttons are hidden, so this
        // script is dormant.
        (function () {
          const drawers = {
            toc: document.querySelector('[data-drawer="toc"]'),
            glossary: document.querySelector('[data-drawer="glossary"]'),
          };
          const backdrop = document.querySelector('[data-backdrop]');
          const toggles = document.querySelectorAll('[data-toggle]');
          if (!backdrop) return;

          function setOpen(name, open) {
            const el = drawers[name];
            if (!el) return;
            el.dataset.open = open ? 'true' : 'false';
            const btn = document.querySelector('[data-toggle="' + name + '"]');
            if (btn) btn.setAttribute('aria-expanded', open ? 'true' : 'false');
            const anyOpen = Object.keys(drawers).some(
              (k) => drawers[k] && drawers[k].dataset.open === 'true',
            );
            backdrop.dataset.open = anyOpen ? 'true' : 'false';
            document.body.style.overflow = anyOpen ? 'hidden' : '';
          }

          function closeAll() {
            for (const name of Object.keys(drawers)) setOpen(name, false);
          }

          toggles.forEach((btn) => {
            btn.addEventListener('click', (e) => {
              e.preventDefault();
              const name = btn.getAttribute('data-toggle');
              if (!name) return;
              const isOpen = drawers[name] && drawers[name].dataset.open === 'true';
              // If the other drawer is open, close it first so they don't
              // stack — visually distracting on a narrow screen.
              for (const k of Object.keys(drawers)) if (k !== name) setOpen(k, false);
              setOpen(name, !isOpen);
            });
          });

          backdrop.addEventListener('click', closeAll);

          document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') closeAll();
          });

          // Close on in-drawer link tap so a TOC selection takes you to the
          // slide rather than leaving the drawer open over the new page.
          for (const name of Object.keys(drawers)) {
            const d = drawers[name];
            if (!d) continue;
            d.addEventListener('click', (e) => {
              const a = e.target.closest && e.target.closest('a[href]');
              if (a) closeAll();
            });
          }

          // Glossary deep-link: when a Term marker (†) is tapped on a narrow
          // viewport, the glossary entry would normally be display:none.
          // Open the drawer and scroll the entry into view.
          function isNarrow() {
            return window.matchMedia('(max-width: 1139px)').matches;
          }
          document.addEventListener('click', (e) => {
            const term = e.target.closest && e.target.closest('.napkin-term');
            if (!term || !isNarrow()) return;
            e.preventDefault();
            const href = term.getAttribute('href') || '';
            const id = href.startsWith('#') ? href.slice(1) : '';
            setOpen('glossary', true);
            if (id) {
              requestAnimationFrame(() => {
                const target = document.getElementById(id);
                if (target) target.scrollIntoView({ block: 'center', behavior: 'smooth' });
                // Reflect the anchor in the URL so the entry's `:target`
                // highlight matches the existing styling.
                history.replaceState(null, '', '#' + id);
              });
            }
          });
        })();
      </script>
    )}

    <style is:global>
      /* Header toggle buttons are sidebar-twin: only shown when the
         corresponding sidebar would otherwise be hidden. */
      .napkin-toc-toggle { display: none; }
      .napkin-glossary-toggle { display: none; }
      @media (max-width: 1319px) {
        .napkin-toc-toggle { display: inline-flex; }
      }
      @media (max-width: 1139px) {
        .napkin-glossary-toggle { display: inline-flex; }
      }

      .napkin-drawer-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.55);
        z-index: 40;
        opacity: 0;
        pointer-events: none;
        transition: opacity 150ms ease;
      }
      .napkin-drawer-backdrop[data-open="true"] {
        opacity: 1;
        pointer-events: auto;
      }
    </style>
  </body>
</html>
