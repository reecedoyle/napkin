---
import SlideLayout from '../layouts/SlideLayout.astro';
import {
  getAllSlides,
  chapterTitles,
  sectionTitles,
} from '../lib/slide-nav';

const slides = getAllSlides();

// Group slides → chapter → section
type SectionGroup = { dir: string; firstSlideUrl: string; slideCount: number };
type ChapterGroup = { dir: string; firstSlideUrl: string; sections: SectionGroup[] };

const chapterMap = new Map<string, Map<string, typeof slides[number][]>>();
for (const s of slides) {
  if (!chapterMap.has(s.chapter)) chapterMap.set(s.chapter, new Map());
  const inChap = chapterMap.get(s.chapter)!;
  if (!inChap.has(s.section)) inChap.set(s.section, []);
  inChap.get(s.section)!.push(s);
}

const chapters: ChapterGroup[] = [...chapterMap.entries()].map(([chapDir, sectMap]) => {
  const sections: SectionGroup[] = [...sectMap.entries()].map(([sectDir, ss]) => ({
    dir: sectDir,
    firstSlideUrl: ss[0].url,
    slideCount: ss.length,
  }));
  return {
    dir: chapDir,
    firstSlideUrl: sections[0]?.firstSlideUrl ?? '#',
    sections,
  };
});
---
<SlideLayout title="An Infinitely Large Napkin">
  <p>
    An interactive companion to Evan Chen's <em>An Infinitely Large Napkin</em>:
    slide-style modules, inline exercises, and progress tracking.
  </p>

  <h2>Pilot — Part I: Starting Out</h2>
  <ul>
    {chapters.map((c) => (
      <li>
        <a href={c.firstSlideUrl}>
          {chapterTitles[c.dir] ?? c.dir}
        </a>
        <ul>
          {c.sections.map((s) => (
            <li>
              <a href={s.firstSlideUrl}>
                {sectionTitles[c.dir]?.[s.dir] ?? s.dir}
              </a>
              <span class="text-stone-500"> · {s.slideCount} slide{s.slideCount === 1 ? '' : 's'}</span>
            </li>
          ))}
        </ul>
      </li>
    ))}
  </ul>

  <p>
    <a href={`${import.meta.env.BASE_URL}glossary`} class="text-stone-600 dark:text-stone-400 underline">
      View glossary
    </a>
  </p>
</SlideLayout>
