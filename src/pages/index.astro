---
import SlideLayout from '../layouts/SlideLayout.astro';
import {
  getAllSlides,
  getSectionTitle,
  partTitles,
  chapterTitles,
} from '../lib/slide-nav';

const slides = getAllSlides();

// Group: part → chapter → section. Preserve URL-sorted order throughout.
type SectionGroup = { dir: string; firstSlideUrl: string; slideCount: number };
type ChapterGroup = {
  dir: string;
  firstSlideUrl: string;
  sections: SectionGroup[];
};
type PartGroup = { dir: string; chapters: ChapterGroup[] };

const partMap = new Map<string, Map<string, Map<string, typeof slides[number][]>>>();
for (const s of slides) {
  if (!partMap.has(s.part)) partMap.set(s.part, new Map());
  const chapMap = partMap.get(s.part)!;
  if (!chapMap.has(s.chapter)) chapMap.set(s.chapter, new Map());
  const sectMap = chapMap.get(s.chapter)!;
  if (!sectMap.has(s.section)) sectMap.set(s.section, []);
  sectMap.get(s.section)!.push(s);
}

const parts: PartGroup[] = [...partMap.entries()].map(([partDir, chapMap]) => {
  const chapters: ChapterGroup[] = [...chapMap.entries()].map(([chapDir, sectMap]) => {
    const sections: SectionGroup[] = [...sectMap.entries()].map(([sectDir, ss]) => ({
      dir: sectDir,
      firstSlideUrl: ss[0].url,
      slideCount: ss.length,
    }));
    return {
      dir: chapDir,
      firstSlideUrl: sections[0]?.firstSlideUrl ?? '#',
      sections,
    };
  });
  return { dir: partDir, chapters };
});
---
<SlideLayout title="An Infinitely Large Napkin">
  <p>
    An interactive companion to Evan Chen's <em>An Infinitely Large Napkin</em>:
    slide-style modules, inline exercises, and progress tracking.
  </p>

  {parts.map((p) => (
    <section>
      <h2>{partTitles[p.dir] ?? p.dir}</h2>
      <ul>
        {p.chapters.map((c) => (
          <li>
            <a href={c.firstSlideUrl}>
              {chapterTitles[`${p.dir}/${c.dir}`] ?? c.dir}
            </a>
            <ul>
              {c.sections.map((s) => (
                <li>
                  <a href={s.firstSlideUrl}>
                    {getSectionTitle(p.dir, c.dir, s.dir)}
                  </a>
                  <span class="text-stone-500"> · {s.slideCount} slide{s.slideCount === 1 ? '' : 's'}</span>
                </li>
              ))}
            </ul>
          </li>
        ))}
      </ul>
    </section>
  ))}

  <p>
    <a href={`${import.meta.env.BASE_URL}glossary`} class="text-stone-600 dark:text-stone-400 underline">
      View glossary
    </a>
  </p>
</SlideLayout>
