---
/**
 * Sidebar pinned to the right edge of the viewport, listing only the
 * glossary entries actually used on the current slide.
 *
 * Each entry gets `id="g-<key>"` so a `<Term>` link can scroll/highlight it.
 */
import katex from 'katex';
import { glossary, type GlossaryEntry } from '../lib/glossary';
import { napkinKatexMacros } from '../lib/katex-macros';

interface Props {
  keys?: string[];
}

const { keys = [] } = Astro.props;
// `as const satisfies ...` narrows each entry to a literal type, which
// makes the union value lose any optional field. Widen back to the
// declared interface for the consumer.
const allEntries = Object.entries(glossary) as [string, GlossaryEntry][];
// Keep entries in glossary.ts declaration order, but only the ones used here.
const entries = keys.length > 0
  ? allEntries.filter(([k]) => keys.includes(k))
  : [];

function renderInlineKatex(src: string): string {
  try {
    return katex.renderToString(src, {
      macros: { ...napkinKatexMacros },
      throwOnError: false,
      displayMode: false,
      strict: 'ignore',
    });
  } catch {
    return src;
  }
}
---
<aside id="napkin-drawer-glossary" class="napkin-glossary-sidebar" aria-label="Glossary for this slide" data-drawer="glossary" data-open="false">
  <div class="napkin-glossary-sidebar-header">
    <h2 class="napkin-glossary-sidebar-title">On this slide</h2>
    {entries.length === 0 && (
      <p class="napkin-glossary-sidebar-empty">No marked notation on this slide.</p>
    )}
  </div>

  {entries.length > 0 && (
    <dl class="napkin-glossary-list">
      {entries.map(([key, entry]) => (
        <div id={`g-${key}`} class="napkin-glossary-item">
          <dt class="napkin-glossary-dt">
            <span class="napkin-glossary-name">{entry.term}</span>
            {entry.symbol && (
              <span class="napkin-glossary-symbol" set:html={renderInlineKatex(entry.symbol)} />
            )}
          </dt>
          <dd class="napkin-glossary-dd">{entry.definition}</dd>
        </div>
      ))}
    </dl>
  )}

  <div class="napkin-glossary-sidebar-footer">
    <a href={`${import.meta.env.BASE_URL}glossary`} class="napkin-glossary-full-link">
      View full glossary →
    </a>
  </div>
</aside>

<style is:global>
  .napkin-glossary-sidebar {
    position: fixed;
    top: 4.5rem;
    right: 1rem;
    width: 280px;
    max-height: calc(100vh - 5.5rem);
    overflow-y: auto;
    padding: 1rem 1rem 1rem 1.25rem;
    border-left: 1px solid rgb(231 229 228);
    font-family: ui-sans-serif, system-ui, sans-serif;
    color: rgb(68 64 60);
    background: rgb(250 250 249);
  }
  @media (prefers-color-scheme: dark) {
    .napkin-glossary-sidebar {
      color: rgb(214 211 209);
      background: rgb(12 10 9);
      border-left-color: rgb(41 37 36);
    }
  }
  /* Below the desktop threshold, become an off-canvas drawer that slides in
     from the right when toggled from the header or via a Term tap. */
  @media (max-width: 1139px) {
    .napkin-glossary-sidebar {
      top: 0;
      right: 0;
      width: min(85vw, 360px);
      max-width: 360px;
      height: 100vh;
      max-height: 100vh;
      padding: 1.25rem 1.25rem 2rem 1.25rem;
      border-left: 1px solid rgb(231 229 228);
      box-shadow: -4px 0 20px rgba(0, 0, 0, 0.18);
      transform: translateX(100%);
      transition: transform 180ms ease;
      z-index: 50;
    }
    .napkin-glossary-sidebar[data-open="true"] {
      transform: translateX(0);
    }
  }

  .napkin-glossary-sidebar-header {
    margin-bottom: 0.75rem;
  }
  .napkin-glossary-sidebar-title {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgb(120 113 108);
    margin: 0 0 0.4rem 0;
    font-weight: 600;
  }
  .napkin-glossary-sidebar-empty {
    font-size: 0.8rem;
    color: rgb(120 113 108);
    margin: 0;
  }
  .napkin-glossary-list {
    margin: 0 0 1rem 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .napkin-glossary-item {
    scroll-margin-top: 1rem;
    padding: 0.4rem 0.5rem;
    border-radius: 4px;
    transition: background-color 200ms;
  }
  .napkin-glossary-item:target {
    background: rgb(254 252 232);
    box-shadow: -2px 0 0 rgb(217 119 6);
  }
  @media (prefers-color-scheme: dark) {
    .napkin-glossary-item:target {
      background: rgb(41 37 36);
      box-shadow: -2px 0 0 rgb(245 158 11);
    }
  }
  .napkin-glossary-dt {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem;
    margin: 0 0 0.15rem 0;
    font-size: 0.85rem;
  }
  .napkin-glossary-name {
    font-weight: 600;
    color: rgb(28 25 23);
  }
  @media (prefers-color-scheme: dark) {
    .napkin-glossary-name { color: rgb(245 245 244); }
  }
  .napkin-glossary-symbol {
    color: rgb(120 113 108);
    font-size: 0.95em;
  }
  .napkin-glossary-symbol .katex { font-size: 0.95em; }
  .napkin-glossary-dd {
    margin: 0;
    font-size: 0.8rem;
    line-height: 1.45;
  }
  .napkin-glossary-sidebar-footer {
    border-top: 1px solid rgb(231 229 228);
    padding-top: 0.75rem;
    font-size: 0.8rem;
  }
  @media (prefers-color-scheme: dark) {
    .napkin-glossary-sidebar-footer { border-top-color: rgb(41 37 36); }
  }
  .napkin-glossary-full-link {
    color: rgb(68 64 60);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgb(168 162 158);
  }
  .napkin-glossary-full-link:hover {
    color: rgb(28 25 23);
    text-decoration-color: rgb(120 113 108);
  }
  @media (prefers-color-scheme: dark) {
    .napkin-glossary-full-link { color: rgb(214 211 209); }
    .napkin-glossary-full-link:hover { color: rgb(245 245 244); }
  }
</style>
