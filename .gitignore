.claude/settings.local.json
.claire/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# generated figures (rebuilt from vendor/napkin/asy)
# Anchored to repo root so it doesn't shadow public/figures/, which holds
# hand-vendored raster assets used by slides.
/figures/

# test artifacts
playwright-report/
test-results/
coverage/
